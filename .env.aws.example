# ============================================================
# AWS production .env — template.
#
# Copy to /opt/tradepro/.env on the host once via SSM session:
#
#   aws ssm start-session --target <instance_id> --region eu-west-2
#   sudo nano /opt/tradepro/.env     # paste + edit
#   sudo systemctl restart tradepro  # picks up the new env
#
# These values are NEVER committed. Real keys live only on the box.
# The terraform module's user-data.sh drops a minimal stub on first
# boot so docker-compose doesn't error before you set the real one.
# ============================================================

# ── ECR + image tag (auto-populated by user-data on first boot) ─
ECR_REGISTRY=108703420282.dkr.ecr.eu-west-2.amazonaws.com
IMAGE_TAG=latest

# ── Host ports the security group exposes ─────────────────────
# Frontend nginx serves on 80 (the user-facing entry point).
# API also exposes 8081 for direct curl/Postman debugging — drop
# the `ports:` block in docker-compose.aws.yaml to make API
# internal-only once the frontend is the only consumer.
FRONTEND_HOST_PORT=80
API_HOST_PORT=8081

# ── Auth ───────────────────────────────────────────────────────
# Production requires Firebase auth on /api/* by default. Flip to
# "false" only for short-lived testing.
FIREBASE_REQUIRE_AUTH=true
# Static token for /api/ingest/* (the Python worker uses this).
# Generate with: openssl rand -hex 32
INGEST_TOKEN=replace-me-with-an-openssl-rand-32

# ── CORS ───────────────────────────────────────────────────────
# Frontend origin allowed to call the API. Once the frontend lives
# on its own AWS host, set this to its public URL.
CORS_ORIGIN_0=http://localhost:5173

# ── Integrations ───────────────────────────────────────────────
# Trading 212 — read-only portfolio. Mode: disabled | demo | live.
# Single API key, no secret (kept for backwards-compat). Get from
# https://www.trading212.com/account/api → "API Settings".
TRADEPRO_T212_MODE=disabled
TRADEPRO_T212_API_KEY=
TRADEPRO_T212_API_SECRET=

# Finnhub earnings calendar — free tier, sign up at finnhub.io.
TRADEPRO_FINNHUB_API_KEY=

# ── Postgres ────────────────────────────────────────────────────
# Local Postgres docker container on the same host. Internal only;
# no port mapped to the host. Credentials are workload-local — not
# the same security domain as T212/Finnhub keys, so a fixed default
# in the .env is fine. Override here if you want something stronger.
POSTGRES_DB=tradepro
POSTGRES_USER=tradepro
POSTGRES_PASSWORD=tradepro

# ── S3 compare-archive (optional, worker side only) ────────────
# OFF by default. Set to 1 to push a copy of every successful API
# ingest to s3://ccit-dev-tradepro-archive/<kind>/... for replay
# history before the Phase D2 Postgres snapshot store lands.
# Requires `pip install boto3` in the worker venv too — without
# boto3 the worker logs a warning and skips silently. Credentials
# come from the dedicated tradepro-archive IAM user (scoped to
# Put/List/Get on this one bucket; never the global AWS profile).
TRADEPRO_S3_ARCHIVE=0
TRADEPRO_S3_ARCHIVE_BUCKET=ccit-dev-tradepro-archive
TRADEPRO_S3_ARCHIVE_REGION=eu-west-2
TRADEPRO_S3_AWS_ACCESS_KEY_ID=
TRADEPRO_S3_AWS_SECRET_ACCESS_KEY=
