# ============================================================
# AWS production .env — template.
#
# Copy to /opt/tradepro/.env on the host once via SSM session:
#
#   aws ssm start-session --target <instance_id> --region eu-west-2
#   sudo nano /opt/tradepro/.env     # paste + edit
#   sudo systemctl restart tradepro  # picks up the new env
#
# These values are NEVER committed. Real keys live only on the box.
# The terraform module's user-data.sh drops a minimal stub on first
# boot so docker-compose doesn't error before you set the real one.
# ============================================================

# ── ECR + image tag (auto-populated by user-data on first boot) ─
ECR_REGISTRY=108703420282.dkr.ecr.eu-west-2.amazonaws.com
IMAGE_TAG=latest

# ── Host port the security group exposes ───────────────────────
# Match the api_port in the terraform module (default 8081).
API_HOST_PORT=8081

# ── Auth ───────────────────────────────────────────────────────
# Production requires Firebase auth on /api/* by default. Flip to
# "false" only for short-lived testing.
FIREBASE_REQUIRE_AUTH=true
# Static token for /api/ingest/* (the Python worker uses this).
# Generate with: openssl rand -hex 32
INGEST_TOKEN=replace-me-with-an-openssl-rand-32

# ── CORS ───────────────────────────────────────────────────────
# Frontend origin allowed to call the API. Once the frontend lives
# on its own AWS host, set this to its public URL.
CORS_ORIGIN_0=http://localhost:5173

# ── Integrations ───────────────────────────────────────────────
# Trading 212 — read-only portfolio. Mode: disabled | demo | live.
# Single API key, no secret (kept for backwards-compat). Get from
# https://www.trading212.com/account/api → "API Settings".
TRADEPRO_T212_MODE=disabled
TRADEPRO_T212_API_KEY=
TRADEPRO_T212_API_SECRET=

# Finnhub earnings calendar — free tier, sign up at finnhub.io.
TRADEPRO_FINNHUB_API_KEY=
