# Copy to `.env` at the repo root. The .env file is gitignored.
#
#   cp .env.compose.example .env
#
# These values are read by docker compose only — they don't apply when you
# run `dotnet run` or `npm run dev` natively.

# Static Bearer token the local API expects on /api/ingest/*. Match this
# with `api_token` in ~/.tradepro/credentials when pushing from the Mac.
INGEST_TOKEN=dev-ingest-token

# Override host ports if 5080 / 5173 are already in use.
API_PORT=5080
FRONTEND_PORT=5173

# Override the API base URL the frontend hits — handy if you tunnel from
# a Codespace or expose the API on a different host.
VITE_API_BASE_URL=http://localhost:5080

# Trading 212 integration. Off by default; set TRADEPRO_T212_MODE to `demo`
# (paper trading) or `live` (real money), then paste the key + secret from
# your T212 app:
#   T212 app → Settings → API (Beta) → Generate new key
#   Permissions needed: Account Metadata + Portfolio (read-only is fine).
# Then `docker compose up -d --force-recreate api` to pick up the new env.
# Verify reachable: curl http://localhost:5080/api/integrations/trading212/status
TRADEPRO_T212_MODE=disabled
TRADEPRO_T212_API_KEY=
TRADEPRO_T212_API_SECRET=

# Finnhub earnings-calendar feed. Off until you set the key. Free
# tier covers 60 req/min, no card needed; sign up at finnhub.io.
# Used to flag "MSFT reports in 5 days" so the digest can warn
# about position-into-earnings volatility risk.
TRADEPRO_FINNHUB_API_KEY=
